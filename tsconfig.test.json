{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "allowImportingTsExtensions": true,
    "composite": true,
    "lib": ["ES2023"],
    "rootDir": ".",
    "tsBuildInfoFile": "./dist/.tsbuildinfo/test.tsbuildinfo",
    "types": ["node"]
  },
  "include": [
    "./scripts/**/*.test.ts",
    "./scripts/**/*.mts",
    "./scripts/setup/**/*.mts",
    "./src/api/**/*.ts",
    "./src/contracts/**/*.ts",
    "./src/main/**/*.ts"
  ]
}
