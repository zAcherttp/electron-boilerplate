{
  "name": "electron-boilerplate",
  "version": "0.1.0",
  "private": true,
  "description": "An incremental Electron, React, and Hono Application API boilerplate",
  "keywords": [
    "boilerplate",
    "electron"
  ],
  "license": "MIT",
  "author": "Electron Boilerplate contributors",
  "main": "dist/main/index.js",
  "scripts": {
    "setup:apply": "node scripts/setup.mts",
    "setup:check": "node scripts/setup.mts --check",
    "setup:dry-run": "node scripts/setup.mts --dry-run",
    "dev": "rimraf dist && vite",
    "debug": "rimraf dist && vite -- --dsb-debug",
    "build": "rimraf dist && vite build",
    "check": "pnpm setup:check && pnpm format:check && pnpm lint && pnpm typecheck && pnpm test && pnpm test:e2e",
    "lint": "oxlint .",
    "lint:fix": "oxlint --fix .",
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "test": "vitest run --root .",
    "test:e2e": "pnpm build && playwright test tests/e2e/application.e2e.ts",
    "test:package": "pnpm package && playwright test tests/e2e/package.e2e.ts",
    "typecheck": "tsc -b --pretty",
    "start": "rimraf dist && vite build && electron .",
    "package": "pnpm build && electron-builder --dir --publish never",
    "dist": "pnpm build && electron-builder --publish never",
    "dist:signed": "pnpm build && electron-builder --publish never --config.forceCodeSigning=true",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "@tanstack/react-query": "5.101.4",
    "@tanstack/react-router": "1.170.18",
    "hono": "4.12.31",
    "pino": "10.3.1",
    "react": "19.2.8",
    "react-dom": "19.2.8",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@base-ui/react": "1.6.0",
    "@fontsource-variable/geist": "5.3.0",
    "@fontsource-variable/geist-mono": "5.3.0",
    "@playwright/test": "1.61.1",
    "@tailwindcss/vite": "4.3.3",
    "@testing-library/dom": "10.4.1",
    "@testing-library/jest-dom": "7.0.0",
    "@testing-library/react": "16.3.2",
    "@types/node": "26.1.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "electron": "43.2.0",
    "electron-builder": "26.15.3",
    "jsdom": "29.1.1",
    "lucide-react": "1.25.0",
    "oxfmt": "0.59.0",
    "oxlint": "1.74.0",
    "oxlint-tsgolint": "0.25.0",
    "pino-pretty": "13.1.3",
    "playwright": "1.61.1",
    "rimraf": "6.1.3",
    "shadcn": "4.13.1",
    "tailwind-merge": "3.6.0",
    "tailwindcss": "4.3.3",
    "tw-animate-css": "1.4.0",
    "typescript": "7.0.2",
    "vite": "8.1.5",
    "vite-plugin-doubleshot": "0.0.25",
    "vitest": "4.1.10"
  },
  "engines": {
    "node": ">=22.18.0"
  },
  "packageManager": "pnpm@11.15.1"
}
