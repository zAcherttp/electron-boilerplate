{
  "name": "electron-boilerplate",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.15.1",
  "description": "An incremental Electron, React, and Hono BFF boilerplate",
  "main": "dist/main/index.js",
  "scripts": {
    "dev": "rimraf dist && vite",
    "debug": "rimraf dist && vite -- --dsb-debug",
    "build": "rimraf dist && vite build",
    "typecheck": "tsc -b --pretty",
    "start": "electron .",
    "package": "pnpm build && electron-builder --dir --publish never",
    "dist": "pnpm build && electron-builder --publish never",
    "postinstall": "electron-builder install-app-deps"
  },
  "keywords": [
    "electron",
    "boilerplate"
  ],
  "license": "UNLICENSED",
  "engines": {
    "node": ">=22.18.0"
  },
  "devDependencies": {
    "@types/node": "^24.13.3",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "electron": "^43.1.0",
    "electron-builder": "26.15.3",
    "rimraf": "6.1.3",
    "typescript": "7.0.2",
    "vite": "8.1.5",
    "vite-plugin-doubleshot": "0.0.25"
  },
  "dependencies": {
    "react": "19.2.7",
    "react-dom": "19.2.7"
  }
}
