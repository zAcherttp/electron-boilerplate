{
  "name": "electron-boilerplate",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.15.1",
  "description": "An incremental Electron, React, and Hono Application API boilerplate",
  "main": "dist/main/index.js",
  "scripts": {
    "dev": "rimraf dist && vite",
    "debug": "rimraf dist && vite -- --dsb-debug",
    "build": "rimraf dist && vite build",
    "lint": "oxlint .",
    "lint:fix": "oxlint --fix .",
    "test": "vitest run --root .",
    "test:e2e": "pnpm build && playwright test",
    "typecheck": "tsc -b --pretty",
    "start": "rimraf dist && vite build && electron .",
    "package": "pnpm build && electron-builder --dir --publish never",
    "dist": "pnpm build && electron-builder --publish never",
    "postinstall": "electron-builder install-app-deps"
  },
  "keywords": [
    "electron",
    "boilerplate"
  ],
  "license": "UNLICENSED",
  "engines": {
    "node": ">=22.18.0"
  },
  "devDependencies": {
    "@playwright/test": "1.61.1",
    "@testing-library/dom": "10.4.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@types/node": "^24.13.3",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "electron": "^43.1.0",
    "electron-builder": "26.15.3",
    "jsdom": "29.1.1",
    "oxlint": "^1.74.0",
    "oxlint-tsgolint": "^0.25.0",
    "playwright": "1.61.1",
    "rimraf": "6.1.3",
    "typescript": "7.0.2",
    "vite": "8.1.5",
    "vite-plugin-doubleshot": "0.0.25",
    "vitest": "^4.1.10"
  },
  "dependencies": {
    "@tanstack/react-query": "5.101.2",
    "@tanstack/react-router": "1.170.18",
    "hono": "^4.12.31",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "zod": "^4.4.3"
  }
}
