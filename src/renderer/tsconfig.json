{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "composite": true,
    "jsx": "react-jsx",
    "lib": ["ES2023", "DOM", "DOM.Iterable"],
    "paths": {
      "@/*": ["./*"]
    },
    "rootDir": "..",
    "tsBuildInfoFile": "../../dist/.tsbuildinfo/renderer.tsbuildinfo",
    "types": ["vite/client"]
  },
  "include": ["./**/*.ts", "./**/*.tsx", "../contracts/**/*.ts"]
}
